    <!-- ===== Splash (يستخدم الثيم الافتراضي دائماً) =====
         ملاحظة: أُزيل windowTranslucentStatus/Navigation لأن النوافذ الشفافة
         قد تُضعف ضمانة FLAG_SECURE في بعض ROMs. -->
    <style name="Theme.Bum.Splash" parent="Theme.Bum">
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="WindowAnimation.Bum" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@anim/slide_up_fade</item>
        <item name="android:activityOpenExitAnimation">@android:anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_down_fade</item>
    </style>

    <style name="BumEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">?attr/bumTextPrimary</item>
        <item name="android:textColorHint">?attr/bumTextHint</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
    </style>

    <style name="BumAlertDialog" parent="Theme.MaterialComponents.Dialog.Alert">
        <item name="android:background">?attr/bumBgCard</item>
        <item name="android:textColorPrimary">?attr/bumTextPrimary</item>
        <item name="colorPrimary">?attr/bumAccent</item>
    </style>

    <style name="BumToolbar" parent="Widget.AppCompat.Toolbar">
        <item name="android:background">?attr/bumBgPrimary</item>
        <item name="titleTextColor">?attr/bumTextPrimary</item>
    </style>

