<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="?attr/bumBgCard"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeColor="?attr/bumBorder"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Thumb -->
        <ImageView
            android:id="@+id/iv_thumb"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_image_placeholder"
            android:visibility="gone"
            android:contentDescription="thumb"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLines="2"
                android:ellipsize="end"
                android:textColor="?attr/bumTextPrimary"
                android:textSize="14sp"
                android:fontFamily="sans-serif" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="?attr/bumTextDim" />

                <TextView
                    android:id="@+id/tv_policy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textSize="11sp"
                    android:textColor="?attr/bumAmber" />

                <TextView
                    android:id="@+id/tv_destroy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💥 تدمير بعد القراءة"
                    android:layout_marginStart="10dp"
                    android:textSize="11sp"
                    android:textColor="?attr/bumDanger"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_delete"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_delete_outline"
            android:scaleType="centerInside"
            android:background="@drawable/bg_icon_btn"
            android:tint="?attr/bumTextDim"
            android:contentDescription="delete" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
