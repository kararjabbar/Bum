<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bumBgPrimary">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_radial_glow" />

    <!-- أيقونة القفل -->
    <ImageView
        android:id="@+id/iv_lock_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_lock"
        android:contentDescription="lock"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.38"
        app:layout_constraintBottom_toBottomOf="parent"
        android:tint="?attr/bumAccent" />

    <!-- عنوان المصادقة -->
    <TextView
        android:id="@+id/tv_auth_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auth_title"
        android:textSize="24sp"
        android:textColor="?attr/bumTextPrimary"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/iv_lock_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp" />

    <!-- وصف -->
    <TextView
        android:id="@+id/tv_auth_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:textColor="?attr/bumTextDim"
        android:fontFamily="sans-serif"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_auth_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="0dp" />

    <!-- رسالة الخطأ -->
    <TextView
        android:id="@+id/tv_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="?attr/bumDanger"
        android:fontFamily="sans-serif"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_auth_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- زر المصادقة -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_authenticate"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:text="@string/btn_authenticate"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:backgroundTint="?attr/bumAccent"
        android:textColor="@color/white"
        app:cornerRadius="26dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="80dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
