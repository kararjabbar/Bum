<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bumBgPrimary">

    <View
        android:id="@+id/view_glow_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ====== Top Header ====== -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/top_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="6dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_logo_small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Būm"
            android:textSize="28sp"
            android:textColor="?attr/bumTextPrimary"
            android:fontFamily="sans-serif-medium"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- v1.4: أزيل العنوان الفرعي "الملاحظات المشفّرة" لأن هذه الشاشة أصبحت
             للملاحظات العادية. القسم المشفّر منفصل تماماً في EncryptedNotesActivity. -->
        <TextView
            android:id="@+id/tv_section_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="• لحظاتي"
            android:textSize="11sp"
            android:textColor="?attr/bumTextSecondary"
            app:layout_constraintStart_toEndOf="@id/tv_logo_small"
            app:layout_constraintBottom_toBottomOf="@id/tv_logo_small"
            android:layout_marginStart="10dp"
            android:layout_marginBottom="6dp" />

        <!-- مجموعة الأيقونات المرتبة في اليمين -->
        <LinearLayout
            android:id="@+id/layout_top_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="@id/tv_logo_small"
            app:layout_constraintBottom_toBottomOf="@id/tv_logo_small"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- v1.4: زر القسم المشفّر المنفصل — يفتح EncryptedNotesActivity -->
            <ImageButton
                android:id="@+id/btn_secret_compartment"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="9dp"
                android:src="@drawable/ic_note_locked"
                android:scaleType="centerInside"
                android:background="@drawable/bg_icon_btn"
                android:tint="?attr/bumTextSecondary"
                android:contentDescription="القسم المشفّر"
                android:layout_marginEnd="10dp" />

            <ImageButton
                android:id="@+id/btn_vault"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_lock"
                android:background="@drawable/bg_icon_btn"
                android:tint="?attr/bumAmber"
                android:contentDescription="vault"
                android:layout_marginEnd="10dp" />

            <ImageButton
                android:id="@+id/btn_settings"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:padding="9dp"
                android:src="@drawable/ic_settings_gear"
                android:scaleType="centerInside"
                android:background="@drawable/bg_icon_btn"
                android:tint="?attr/bumTextSecondary"
                android:contentDescription="settings" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ====== Meta info (date/greeting/status) ====== -->
    <LinearLayout
        android:id="@+id/layout_meta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/top_header"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/bumTextDim"
            android:fontFamily="sans-serif" />

        <TextView
            android:id="@+id/tv_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="?attr/bumTextSecondary"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.1"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="?attr/bumTextPrimary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="10dp" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/bumBorder"
        app:layout_constraintTop_toBottomOf="@id/layout_meta"
        android:layout_marginTop="18dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp" />

    <!-- ====== شريط البحت (v1.2) — الكلمة السرية تظهر الملاحظات الشبحية ====== -->
    <LinearLayout
        android:id="@+id/layout_search"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_search_bar"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_search"
            android:tint="?attr/bumTextDim"
            android:contentDescription="search" />

        <EditText
            android:id="@+id/et_search"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="بحث في اللحظات…"
            android:textSize="14sp"
            android:textColor="?attr/bumTextPrimary"
            android:textColorHint="?attr/bumTextHint"
            android:inputType="text|textNoSuggestions"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:importantForAutofill="no"
            android:autofillHints=""
            android:paddingStart="10dp"
            android:paddingEnd="10dp" />

        <ImageButton
            android:id="@+id/btn_clear_search"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:padding="6dp"
            android:src="@drawable/ic_delete_new"
            android:scaleType="centerInside"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="?attr/bumTextHint"
            android:visibility="gone"
            android:contentDescription="clear" />
    </LinearLayout>

    <!-- ====== List of Notes ====== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_notes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="140dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/layout_search"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- ====== Empty State ====== -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layout_search"
        app:layout_constraintBottom_toTopOf="@id/btn_write"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌙"
            android:textSize="42sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ابدأ بكتابة لحظتك الأولى"
            android:textColor="?attr/bumTextDim"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- ====== زر الكتابة الرئيسي ====== -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_write"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="+  اكتب لحظة جديدة"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/white"
        android:backgroundTint="?attr/bumAccent"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@id/layout_bottom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp" />

    <!-- ====== Bottom meta ====== -->
    <LinearLayout
        android:id="@+id/layout_bottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="26dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tv_wipe_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="?attr/bumTextDim"
            android:fontFamily="sans-serif"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_app_philosophy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ما هو Būm؟"
            android:textSize="12sp"
            android:textColor="?attr/bumTextHint"
            android:fontFamily="sans-serif"
            android:layout_marginStart="14dp"
            android:paddingBottom="3dp"
            android:background="@drawable/bg_underline_dim" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
