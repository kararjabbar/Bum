<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ====== النتيجة ====== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="كلمة المرور المولّدة"
            android:textColor="?attr/bumTextDim"
            android:textSize="11sp"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_generated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:padding="14dp"
            android:background="@drawable/bg_input_field"
            android:textColor="?attr/bumTextPrimary"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:textIsSelectable="true"
            android:textDirection="ltr"
            android:gravity="start|center_vertical" />

        <TextView
            android:id="@+id/tv_strength_meter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="11sp"
            android:textColor="?attr/bumAmber" />

        <!-- ====== الطول ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="18dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="الطول"
                android:textColor="?attr/bumTextPrimary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tv_length_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20"
                android:textColor="?attr/bumAccent"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/sb_length"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="120"
            android:progress="12"
            android:layout_marginTop="4dp" />

        <!-- ====== الفئات ====== -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_upper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="حروف كبيرة (A-Z)"
            android:textColor="?attr/bumTextPrimary"
            android:checked="true"
            android:layout_marginTop="12dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_lower"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="حروف صغيرة (a-z)"
            android:textColor="?attr/bumTextPrimary"
            android:checked="true"
            android:layout_marginTop="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_digits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="أرقام (0-9)"
            android:textColor="?attr/bumTextPrimary"
            android:checked="true"
            android:layout_marginTop="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_symbols"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="رموز (!@#$%...)"
            android:textColor="?attr/bumTextPrimary"
            android:checked="true"
            android:layout_marginTop="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/sw_avoid_ambig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="تجنّب المتشابهات (0/O/1/l/I)"
            android:textColor="?attr/bumTextPrimary"
            android:checked="false"
            android:layout_marginTop="4dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_regenerate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🎲  توليد جديد"
            android:textSize="14sp"
            android:textColor="@color/white"
            app:cornerRadius="12dp"
            android:backgroundTint="?attr/bumAccent"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>
