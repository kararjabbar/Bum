<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_encrypted_notes.xml  (v1.4)
    واجهة "القسم المشفّر المنفصل" — مستقلة تماماً عن الواجهة الرئيسية.
    • هنا كل ملاحظة لها عنوان واضح يوضّح موضوعها قبل فتحها.
    • التصميم يبدو مختلفاً عن MainActivity (header داكن + شريط أمان علوي).
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bumBgPrimary">

    <!-- توهّج خلفية خاص بهذه الشاشة -->
    <View
        android:id="@+id/view_glow_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ====== Header مختلف عن الواجهة الرئيسية ====== -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_icon_btn"
            android:tint="?attr/bumTextSecondary"
            android:contentDescription="back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔐  القسم المشفّر"
                android:textColor="?attr/bumTextPrimary"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ملاحظات محمية بعناوين واضحة"
                android:textColor="?attr/bumAccent"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_count_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_input_field"
            android:textColor="?attr/bumAmber"
            android:textSize="11sp"
            android:text="0" />
    </LinearLayout>

    <!-- شريط أمان -->
    <LinearLayout
        android:id="@+id/security_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🛡️  AES-256-GCM • بدون سحابة • بدون إنترنت"
            android:textColor="?attr/bumTextDim"
            android:textSize="11sp" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/bumBorder"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/security_banner" />

    <!-- قائمة الملاحظات المشفّرة -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_encrypted"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="140dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- حالة فارغة -->
    <LinearLayout
        android:id="@+id/layout_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/divider"
        app:layout_constraintBottom_toTopOf="@id/btn_new_secret"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔐"
            android:textSize="42sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="لا ملاحظات مشفّرة بعد"
            android:textColor="?attr/bumTextDim"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="كل ملاحظة هنا ستحمل عنواناً واضحاً"
            android:textColor="?attr/bumTextHint"
            android:textSize="11sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- زر إضافة ملاحظة مشفّرة جديدة -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_new_secret"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="+  ملاحظة مشفّرة جديدة"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/white"
        android:backgroundTint="?attr/bumAccent"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="26dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
