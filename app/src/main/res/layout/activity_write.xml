<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bumBgPrimary">

    <LinearLayout
        android:id="@+id/layout_writing"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/layout_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="0dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:background="@drawable/bg_icon_btn"
                android:tint="?attr/bumTextSecondary"
                android:contentDescription="back" />

            <TextView
                android:id="@+id/tv_header_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="لحظة جديدة"
                android:textSize="17sp"
                android:textColor="?attr/bumTextPrimary"
                android:fontFamily="sans-serif-medium"
                android:gravity="center" />

            <!-- v1.2: زر تبديل "الملاحظة الشبحية" — يخفي الملاحظة كلياً عن القائمة الرئيسية -->
            <ImageButton
                android:id="@+id/btn_ghost_toggle"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_ghost"
                android:scaleType="centerInside"
                android:background="@drawable/bg_ghost_toggle"
                android:tint="?attr/bumTextSecondary"
                android:contentDescription="ghost mode" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/bumBorder"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="16dp" />

        <!-- v1.4: حقل العنوان — يظهر فقط عند الدخول من القسم المشفّر -->
        <LinearLayout
            android:id="@+id/layout_title_wrapper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="14dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝  عنوان يوضّح موضوع الملاحظة"
                android:textColor="?attr/bumTextDim"
                android:textSize="11sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_title"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:hint="مثالً: رموز الاستعادة، ملاحظة دائرة، ..."
                android:textColor="?attr/bumTextPrimary"
                android:textColorHint="?attr/bumTextHint"
                android:textSize="14sp"
                android:inputType="text|textCapSentences|textNoSuggestions"
                android:singleLine="true"
                android:gravity="start|center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:maxLength="80"
                android:importantForAutofill="no"
                android:autofillHints="" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_content"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:hint="@string/hint_write"
            android:textSize="17sp"
            android:textColor="?attr/bumTextPrimary"
            android:textColorHint="?attr/bumTextHint"
            android:fontFamily="sans-serif"
            android:background="@android:color/transparent"
            android:inputType="textMultiLine|textCapSentences"
            android:gravity="top|start"
            android:lineSpacingMultiplier="1.5"
            android:maxLength="500"
            android:imeOptions="flagNoExtractUi"
            android:paddingBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="?attr/bumTextHint"
            android:textSize="11sp"
            android:layout_marginBottom="0dp"
            android:visibility="gone" />

        <HorizontalScrollView
            android:id="@+id/scroll_attachments"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:visibility="gone">
            <LinearLayout
                android:id="@+id/layout_attachments"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="4dp"
                android:paddingBottom="12dp" />
        </HorizontalScrollView>

        <!-- صف العداد + زر المرفق -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tv_char_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="12sp"
                android:textColor="?attr/bumTextDim" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/500"
                android:textSize="12sp"
                android:textColor="?attr/bumTextHint"
                android:layout_marginStart="2dp" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_attach"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:text="مرفق"
                android:textSize="12sp"
                app:icon="@drawable/ic_attach_file"
                app:iconSize="16dp"
                app:iconGravity="textStart"
                app:iconPadding="6dp"
                app:iconTint="?attr/bumTextSecondary"
                android:backgroundTint="?attr/bumBgElevated"
                android:textColor="?attr/bumTextSecondary"
                app:cornerRadius="21dp"
                app:strokeColor="?attr/bumBorder"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <!-- زر الكاميرا بالوسط (كما طلب المستخدم) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="14dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_camera"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="@string/btn_camera"
                android:textSize="13sp"
                app:icon="@drawable/ic_camera"
                app:iconSize="18dp"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="?attr/bumAmber"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:backgroundTint="?attr/bumBgElevated"
                android:textColor="?attr/bumTextPrimary"
                app:cornerRadius="24dp"
                app:strokeColor="?attr/bumAmber"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_save"
            android:textSize="15sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/white"
            android:backgroundTint="?attr/bumAccent"
            app:cornerRadius="14dp"
            android:layout_marginBottom="16dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_camera_mode"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.camera.view.PreviewView
                android:id="@+id/camera_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/black" />

            <ImageView
                android:id="@+id/iv_captured_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="captured preview" />

            <View
                android:id="@+id/flash_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white"
                android:alpha="0.8"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/layout_image_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="?attr/bumBgElevated"
            android:padding="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📝  ملاحظة مع الصورة (اختياري)"
                android:textColor="?attr/bumTextDim"
                android:textSize="11sp"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_image_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="أضف ملاحظة توضح هذه اللحظة..."
                android:textColor="?attr/bumTextPrimary"
                android:textColorHint="?attr/bumTextHint"
                android:textSize="14sp"
                android:background="@android:color/transparent"
                android:inputType="textMultiLine|textCapSentences"
                android:maxLines="3"
                android:maxLength="200" />
        </LinearLayout>

        <!-- 🎯 v1.3: زر الالتقاط بالوسط تماماً (RelativeLayout لضمان التمركز) -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="@drawable/bg_camera_controls">

            <!-- زر الإلغاء: يسار الشاشة -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel_camera"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:text="✕  إلغاء"
                android:textSize="13sp"
                android:backgroundTint="?attr/bumBgElevated"
                android:textColor="?attr/bumTextSecondary"
                app:cornerRadius="26dp"
                app:strokeColor="?attr/bumBorder"
                app:strokeWidth="1dp" />

            <!-- زر الالتقاط: في منتصف الشاشة تماماً -->
            <ImageButton
                android:id="@+id/btn_capture"
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_circle_accent"
                android:src="@drawable/ic_camera_shutter"
                android:tint="@color/white"
                android:contentDescription="capture" />

            <!-- زر إعادة الالتقاط: يمين الشاشة (يظهر بعد التقاط الصورة) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_retake"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="↺  إعادة"
                android:textSize="13sp"
                android:backgroundTint="?attr/bumBgElevated"
                android:textColor="?attr/bumTextSecondary"
                app:cornerRadius="26dp"
                app:strokeColor="?attr/bumBorder"
                app:strokeWidth="1dp"
                android:visibility="gone" />

            <!-- زر الحفظ: يمين الشاشة (يظهر بعد الالتقاط بدل إعادة) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save_image"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="✓  حفظ"
                android:textSize="13sp"
                android:textColor="@color/white"
                android:backgroundTint="?attr/bumAccent"
                app:cornerRadius="26dp"
                android:visibility="gone" />
        </RelativeLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_save_success"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_input_field"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/save_success"
            android:textColor="?attr/bumTextPrimary"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
