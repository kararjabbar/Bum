<?xml version="1.0" encoding="utf-8"?>
<!-- v1.4: Dialog موحّد لتعيين كلمة مرور — autofill معطّل + اتجاه موحّد start -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:importantForAutofill="noExcludeDescendants"
    tools:importantForContentCapture="no">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="كلمة المرور الجديدة"
        android:textColor="?attr/bumTextDim"
        android:textSize="11sp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input_field"
        android:hint="4 أحرف على الأقل"
        android:textColor="?attr/bumTextPrimary"
        android:textColorHint="?attr/bumTextHint"
        android:textSize="14sp"
        android:inputType="text|textNoSuggestions"
        android:singleLine="true"
        android:importantForAutofill="noExcludeDescendants"
        android:autofillHints=""
        android:gravity="start|center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        tools:importantForContentCapture="no" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تأكيد كلمة المرور"
        android:textColor="?attr/bumTextDim"
        android:textSize="11sp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="6dp" />

    <EditText
        android:id="@+id/et_password_confirm"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:background="@drawable/bg_input_field"
        android:hint="اكتبها مرة أخرى"
        android:textColor="?attr/bumTextPrimary"
        android:textColorHint="?attr/bumTextHint"
        android:textSize="14sp"
        android:inputType="text|textNoSuggestions"
        android:singleLine="true"
        android:importantForAutofill="noExcludeDescendants"
        android:autofillHints=""
        android:gravity="start|center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        tools:importantForContentCapture="no" />

    <TextView
        android:id="@+id/tv_match_indicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="11sp"
        android:textColor="?attr/bumTextDim"
        android:text=" " />
</LinearLayout>
